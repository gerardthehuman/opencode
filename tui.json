{
  "plugin_enabled": {
    "humanforce.forge": true,
    "internal:sidebar-context": false
  },
  "theme": "forge",
  "$schema": "https://opencode.ai/tui.json",
  "plugin": [
    ["./plugins/forge-tui.tsx", {}],
    [
      "./plugins/progress-relay.tsx",
      {
        "hidden": false,
        "max_agents": 4,
        "show_findings": false,
        "scope": "turn"
      }
    ],
    [
      "./plugins/token-tracker.tsx",
      {
        "last_turn": {
          "hidden": true,
          "include_children": true
        },
        "session": {
          "hidden": false,
          "include_children": true
        }
      }
    ]
  ]
}
