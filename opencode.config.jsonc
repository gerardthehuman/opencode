{
  // User-managed OpenCode preferences. Applied by `npm run configure`
  // (scripts/configure.ts) on top of Forge's generated opencode.jsonc.
  // Forge may re-merge broker/catalog fields; re-run configure after that.
  "$schema": "https://opencode.ai/config.json",

  "plugin": [
    "oh-my-opencode-slim",
    [
      "@plannotator/opencode",
      {
        "workflow": "plan-agent",
        "planningAgents": ["plan", "lead", "orchestrator"]
      }
    ]
  ],

  "model": "openrouter/deepseek/deepseek-v4-pro",
  "small_model": "openrouter/x-ai/grok-build-0.1",
  "default_agent": "lead",

  "permission": {
    "external_directory": {
      "/tmp/**": "allow",
      "/var/**": "allow",
      "~/.agents/**": "allow",
      "*": "allow"
    }
  },

  // Forge MCP via env interpolation (no hardcoded URL/token).
  "mcp": {
    "forge": {
      "type": "remote",
      "url": "{env:FORGE_MCP_URL}",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:FORGE_MCP_TOKEN}"
      }
    }
  }
}
