{
  "enabled_providers": [
    "openrouter"
  ],
  "provider": {
    "openrouter": {
      "name": "Forge (OpenRouter)",
      "options": {
        "baseURL": "{env:FORGE_OPENROUTER_BROKER_BASE_URL}",
        "apiKey": "{env:FORGE_SUPABASE_ACCESS_TOKEN}",
        "headers": {
          "HTTP-Referer": "https://forge.humanforce.com",
          "X-Title": "Forge OpenCode"
        }
      },
      "models": {
        "deepseek/deepseek-v4-pro": {
          "name": "Default (Forge)",
          "limit": {
            "context": 200000,
            "output": 16384
          },
          "cost": {
            "input": 3,
            "output": 15,
            "cache_read": 0.3
          }
        },
        "z-ai/glm-5.2": {
          "name": "GLM 5.2 (Forge)",
          "limit": {
            "context": 1000000,
            "output": 16384
          },
          "cost": {
            "input": 1.2,
            "output": 4.2,
            "cache_read": 0
          }
        },
        "x-ai/grok-build-0.1": {
          "name": "Grok Build (Forge)",
          "limit": {
            "context": 256000,
            "output": 16384
          },
          "cost": {
            "input": 1,
            "output": 2,
            "cache_read": 0
          }
        },
        "anthropic/claude-opus-4.8": {
          "name": "Claude Opus 4.8 (Forge)",
          "limit": {
            "context": 1000000,
            "output": 16384
          }
        },
        "moonshotai/kimi-k2.7-code": {
          "name": "Kimi K2.7 Code (Forge)",
          "limit": {
            "context": 262000,
            "output": 16384
          }
        },
        "x-ai/grok-4.5": {
          "name": "Grok 4.5 (Forge)",
          "limit": {
            "context": 500000,
            "output": 16384
          },
          "cost": {
            "input": 2,
            "output": 6,
            "cache_read": 0.5
          }
        },
        "anthropic/claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6 (Forge)",
          "limit": {
            "context": 1000000,
            "output": 16384
          }
        }
      },
      "whitelist": [
        "deepseek/deepseek-v4-pro",
        "z-ai/glm-5.2",
        "x-ai/grok-build-0.1",
        "anthropic/claude-opus-4.8",
        "moonshotai/kimi-k2.7-code",
        "x-ai/grok-4.5",
        "anthropic/claude-sonnet-4.6"
      ]
    }
  },
  "$schema": "https://opencode.ai/config.json",
  "model": "openrouter/deepseek/deepseek-v4-pro",
  "small_model": "openrouter/x-ai/grok-build-0.1",
  "default_agent": "lead",
  "permission": {
    "external_directory": {
      "/tmp/**": "allow",
      "/var/**": "allow",
      "~/.agents/**": "allow",
      "*": "allow"
    }
  },
  "plugin": [
    "oh-my-opencode-slim",
    [
      "@plannotator/opencode",
      {
        "workflow": "plan-agent",
        "planningAgents": [
          "plan",
          "lead"
        ]
      }
    ]
  ],
  "mcp": {
    "forge": {
      "type": "remote",
      "url": "{env:FORGE_MCP_URL}",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:FORGE_MCP_TOKEN}"
      }
    }
  }
}
